---
import { Image } from "astro:assets";
import bgAgenda from "../assets/bg_agenda.png";
import logoHSI from "../assets/Logo-HSI-01-768x734.png";
import VIForo from "../assets/VIForo2026.svg";
import heroLogoMobile from "../assets/hero-logo-mobile-min.png";
import msLogoMedicaSur from "../assets/medica_sur.png";


---

<section class="relative w-full min-h-[500px] flex items-center overflow-hidden py-12 px-6 md:px-12 bg-white">
  
  <!-- BACKGROUND LAYER (Cápsulas y Logo HSI) -->
  <div class="absolute inset-0 z-0">
    <Image 
      src={bgAgenda} 
      alt="" 
      class="w-full h-full object-cover object-center"
      quality={100}
    />
  </div>
</section>

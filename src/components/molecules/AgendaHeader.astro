        src={heroLogoMobile}
        width={289}
        height={105}
        alt="Doctores"
        loading="lazy"
        class="hidden md:block shrink-0 object-contain h-auto w-[250px] lg:w-[289px]"
    />-->
<Image
        src={heroLogoMobile}
        alt="Doctores"
        loading="lazy"
        class="hidden md:block w-[334px] h-[406px]"
    />


    <Image
        src={logoHSI}
        width={69}
        height={65}
        alt="HSI"
        loading="lazy"
        class="hidden md:block w-[69px] h-[65px]"
    />
</div>

</section>
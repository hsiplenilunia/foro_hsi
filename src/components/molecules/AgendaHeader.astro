---
import { Image } from "astro:assets";
import logoHSI from "../../assets/Logo-HSI-01-768x734.png";
import VIForo from "../../assets/VIForo2026.svg";
import heroLogoMobile from "../assets/hero-logo-mobile-min.png";
import msLogoMedicaSur from "../../assets/medica_sur.png";

---

<section class="relative w-full bg-white overflow-hidden py-12 px-6 md:px-12">
  
  <div class="absolute top-4 right-8 flex items-center gap-4">

     <Image src={logoHSI} alt="Logo HSI" class="w-12 h-auto" width={50} height={50} />
  </div>

  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-10">
    
    <div class="flex flex-col items-center space-y-2">

      <Image 
        src={VIForo} 
        alt="VI Foro 2026" 
        class="w-40 md:w-56 h-auto" 
        width={236} 
        height={253} 
      />
  
    </div>

    <div class="flex-1 flex flex-col items-start">
      <h1 class="text-[#204356] text-6xl md:text-8xl font-black leading-none tracking-tighter">
        AGENDA
      </h1>
      <h2 class="text-[#204356] text-3xl md:text-5xl font-light tracking-[0.2em] uppercase mt-[-10px] mb-8">
        Preliminar
      </h2>
      
      <div class="space-y-1">
        <p class="text-[#204356] text-2xl md:text-3xl font-black">
          27 Y 28 DE AGOSTO, 2026
        </p>
        <p class="text-gray-600 text-lg md:text-xl font-medium tracking-wide">
          SEDE | <span class="font-bold">Auditorio Médica Sur</span>
        </p>
      </div>
      
      <img src="/wave-line.svg" alt="" class="w-full max-w-md mt-6" />
    </div>

    <div class="relative w-full md:w-1/3 flex justify-center">

      <div class="absolute -top-10 -right-5 opacity-40 w-20 h-auto blur-[1px]">

      </div>
    </div>
  </div>

  <div class="flex flex-col md:flex-row items-center gap-6">
    <div class="flex items-center gap-4">

      <div class="w-px h-10 bg-gray-300 hidden md:block"></div>
      <p class="text-[#204356] italic text-sm font-bold leading-tight max-w-[200px]">
        Institución sede comprometida con el combate a las infecciones
      </p>
    </div>
  </div>

</section>
---
import { Image } from "astro:assets";
import logoHSI from "../../assets/Logo-HSI.svg";
import VIForo from "../../assets/VIForo2026.svg";
import heroLogoMobile from "../../assets/hero-logo-mobile-min.png";
import msLogoMedicaSur from "../../assets/medica-sur.svg";

// Estilos base para la sección (opcional si decides usarlos en la etiqueta section)
const sectionStyles = `landing-section bg-bg-white w-screen flex items-center justify-center pt-24 px-8 relative`;
---

<section
  class="relative w-full overflow-hidden py-16 px-6 md:px-12 min-h-[500px] flex items-center bg-white 
         bg-[url('/bg-agenda.png')] bg-no-repeat
         bg-[length:auto_100%] bg-right 
         md:bg-cover md:bg-center"
>
  <!-- Contenedor Principal con Espaciado Reservado para Doctores -->
  <div class="flex w-full max-w-7xl mx-auto justify-center md:justify-start items-center gap-8 md:pr-[400px]">
    
    <!-- Logo VI Foro -->
    <div class="shrink-0">
      <Image
        src={VIForo}
        width={236}
        height={253}
        alt="Logo VI Foro"
        loading="lazy"
        class="w-[180px] md:w-[236px] h-auto"
      />
    </div>

    <!-- Bloque de Texto Central -->
    <div class="flex flex-col space-y-4">
      <header>
        <h1 class="text-blue-text text-5xl md:text-7xl font-bold leading-tight">AGENDA</h1>
        <h2 class="text-blue-text text-3xl md:text-4xl font-light">PRELIMINAR</h2>
      </header>

      <div class="space-y-1">
        <p class="text-blue-text text-2xl tracking-wider font-bold">
          27 Y 28 DE Agosto, 2026
        </p>
        <p class="text-blue-text text-xl font-normal tracking-widest">
          SEDE | <strong class="font-extrabold">Auditorio del Hospital Médica Sur</strong>
        </p>
      </div>

      <!-- Línea decorativa -->
      <img 
        src="/wave-line.svg" 
        alt="" 
        class="w-[180px] md:w-[450px] py-4 h-auto" 
        aria-hidden="true" 
      />

      <!-- MédicaSur logo + texto institucional -->
      <div class="flex items-center gap-4">
        <Image
          src={msLogoMedicaSur}
          alt="Médica Sur"
          class="h-14 w-auto"
          width={224}
          height={52}
          loading="lazy"
        />
        <div class="w-px h-14 bg-gray-400"></div>
        <p class="font-bold text-blue-text italic text-base leading-snug max-w-[280px]">
          Institución sede comprometida con el combate a las infecciones
        </p>
      </div>
    </div>
  </div>

  <!-- IMAGEN DOCTORES: Posicionamiento Absoluto para crecer arriba/abajo -->
  <div class="hidden md:block absolute right-[10%] top-1/2 -translate-y-1/2 z-10">
    <Image
      src={heroLogoMobile}
      alt="Doctores"
      loading="lazy"
      class="min-w-[480px] lg:min-w-[550px] h-auto object-contain"
    />
  </div>

  <!-- LOGO HSI: Posicionado en la esquina superior derecha -->
  <div class="hidden md:block absolute top-8 right-12">
    <Image
      src={logoHSI}
      width={80}
      height={75}
      alt="HSI"
      loading="lazy"
      class="w-[80px] h-auto"
    />
  </div>

</section>
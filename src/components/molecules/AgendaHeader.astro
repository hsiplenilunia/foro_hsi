---
import { Image } from "astro:assets";
import logoHSI from "../../assets/Logo-HSI.svg";
import VIForo from "../../assets/VIForo2026.svg";
import heroLogoMobile from "../../assets/hero-logo-mobile-min.png";
import msLogoMedicaSur from "../../assets/medica-sur.svg";
---

<section
  class="relative w-full overflow-hidden py-10 px-6 md:px-12 min-h-[450px] bg-white
         bg-[url('/bg-agenda.png')] bg-no-repeat
         bg-[length:auto_100%] bg-right
         md:bg-cover md:bg-center"
>

  <!-- ===== DESKTOP LAYOUT ===== -->
  <div class="hidden md:flex flex-row w-full justify-center gap-8 items-start">

    <Image
      src={VIForo}
      width={182}
      height={164}
      alt="Logo VI Foro"
      loading="lazy"
      class="min-w-[182px] w-[236px] h-[253px]"
    />

    <div class="flex flex-col items-start text-left w-auto">
      <h1 class="text-blue-text text-6xl font-bold leading-none">AGENDA</h1>
      <h2 class="text-blue-text text-3xl font-normal mt-1">PRELIMINAR</h2>
      <p class="text-blue-text text-2xl tracking-wider font-bold mt-2">
        27 Y 28 DE AGOSTO, 2026
      </p>
      <p class="text-blue-text text-xl font-thin tracking-widest mt-1">
        SEDE | <strong class="font-extrabold">Auditorio del Hospital Médica Sur</strong>
      </p>
      <img src="/wave-line.svg" alt="" class="w-[450px] mt-4 mb-2 h-auto" aria-hidden="true" />
      <!-- MédicaSur desktop — fila horizontal -->
      <div class="flex items-center gap-2 mt-2">
        <Image
          src={msLogoMedicaSur}
          alt="Médica Sur"
          class="h-12 w-auto"
          width={224}
          height={52}
          loading="lazy"
          format="svg"
          quality={80}
        />
        <div class="w-px h-12 bg-gray-400"></div>
        <p class="font-bold text-blue-text italic text-base leading-snug text-left max-w-[280px]">
          Institución sede comprometida<br />con el combate a las infecciones
        </p>
      </div>
    </div>

    <Image
      src={heroLogoMobile}
      alt="Doctores"
      loading="lazy"
      class="w-[334px] h-[406px]"
    />

    <Image
      src={logoHSI}
      width={69}
      height={65}
      alt="HSI"
      loading="lazy"
      class="w-[69px] h-[65px]"
    />

  </div>
  <!-- END DESKTOP -->

  <!-- MOBILE LAYOUT -->
  <div class="md:hidden flex flex-col items-start text-left w-full gap-0">

    <!-- Logo VI Foro Mobile -->
    <Image
      src={VIForo}
      width={182}
      height={164}
      alt="Logo VI Foro"
      loading="lazy"
      class="w-[120px] h-auto mb-4"
    />

    <!-- AGENDA PRELIMINAR MOBILE -->
    <h1 class="text-blue-text text-5xl font-bold leading-none">AGENDA</h1>
    <h2 class="text-blue-text text-2xl font-normal mt-1">PRELIMINAR</h2>

    <!-- Fecha del Foro Mobile-->
    <p class="text-blue-text text-xl tracking-wider font-bold mt-3">
      27 Y 28 DE AGOSTO, 2026
    </p>

    <!-- Textos SEDE Mobile -->
    <p class="text-blue-text text-lg font-thin tracking-widest mt-1">
      SEDE | <strong class="font-extrabold">Auditorio Médica Sur</strong>
    </p>

    <!-- Wave line -->
    <img src="/wave-line.svg" alt="" class="w-full mt-4 mb-4 h-auto" aria-hidden="true" />

    <!-- MédicaSur mobile -->
    <div class="flex flex-col items-center w-full gap-2 mt-2">
      <Image
        src={msLogoMedicaSur}
        alt="Médica Sur"
        class="h-14 w-auto"
        width={224}
        height={52}
        loading="lazy"
        format="svg"
        quality={80}
      />
      <p class="font-bold text-blue-text italic text-base leading-snug text-center">
        Institución sede comprometida<br />con el combate a las infecciones
      </p>
    </div>

  </div>
  <!-- END MOBILE -->

</section>
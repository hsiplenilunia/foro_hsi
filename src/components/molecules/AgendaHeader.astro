---
import { Image } from "astro:assets";
import logoHSI from "../../assets/Logo-HSI-01-768x734.png";
import VIForo from "../../assets/VIForo2026.svg";
import heroLogoMobile from "../../assets/hero-logo-mobile-min.png";
---

<div class="flex w-full justify-center gap-8">
    <Image
      src={VIForo}
      alt="VI Foro"
      class="h-32 w-32"
      width={236}
      height={253}
      loading="lazy"
      decoding="async"
      format="svg"
      quality={80}
    />
   <div>
        <h2 class="text-5xl md:text-6xl text-blue-text mb-8">Agenda</h2>
        <h3 class="text-blue-text text-3xl md:text-6xl font-normal ">
            <span class="text-4xl md:text-7xl">Preliminar</span>
        </h3>
        <p class="text-2xl tracking-wider font-bold text-blue-text mt-2">
            25 Y 26 DE Agosto, 2026
        </p>
        <p class="text-blue-text text-xl font-normal tracking-widest mt-1">
            SEDE | Auditorio del <strong class="font-extrabold">Hospital Médica Sur</strong>
        </p>
        <img src="/wave-line.svg" alt="" class="w-48 mt-2 opacity-50" aria-hidden="true" />
        <div>
        </div>
    </div>
    <Image
        src={heroLogoMobile}
        width={289}
        height={105}
        alt="Logotipo principal del Foro HSI para dispositivos móviles"
        loading="lazy"
        class="hidden md:block"
    />
    <Image
        src={logoHSI}
        width={69}
        height={65}
        alt="Logotipo institucional HSI"
        loading="lazy"
        class="hidden md:block w-[69px] h-[65px]"
    />
</div>
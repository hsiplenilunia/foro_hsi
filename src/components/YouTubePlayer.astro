---
const { id, url, title = "Video de YouTube", class: className = "" } = Astro.props;

// Función mejorada para detectar tipo de contenido y extraer ID
function getYouTubeData(url) {
  const isPlaylist = url.includes('list=');
  
  if (isPlaylist) {
    const listMatch = url.match(/[?&]list=([^#&?]+)/);
    return {
      id: listMatch ? listMatch[1] : null,
      type: 'playlist',
      // Miniatura por defecto para listas (puedes usar una propia del foro)
      thumbnail: "https://res.cloudinary.com/dokvwbz1c/image/upload/bg_player.png?q=80&w=1200&auto=format&fit=crop" 
    };
  } else {
    const ytMatch = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|v\/))([\w-]{11})/);
    const vId = ytMatch ? ytMatch[1] : url;
    return {
      id: vId,
      type: 'video',
      thumbnail: `https://img.youtube.com/vi/${vId}/maxresdefault.jpg`
    };
  }
}

const ytData = getYouTubeData(url);
---

<div class={`aspect-video w-full shadow-xl rounded-xl overflow-hidden relative ${className}`}>
  <div
    id={`yt-lite-${id}`}
    class="absolute inset-0 w-full flex items-center justify-center cursor-pointer bg-slate-900"
    style={`background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('${ytData.thumbnail}') center/cover no-repeat;`}
    tabindex="0"
    role="button"
    data-yt-id={ytData.id}
    data-yt-type={ytData.type}
    data-title={title}
  >
    <!-- Botón Play -->
    <div class="group flex items-center justify-center w-20 h-20 rounded-full bg-blue-600 transition-transform group-hover:scale-110">
      <svg width="40" height="40" fill="white" viewBox="0 0 24 24" class="ml-1">
        <path d="M8 5v14l11-7z"></path>
      </svg>
    </div>
    
    {ytData.type === 'playlist' && (
      <div class="absolute bottom-4 right-4 bg-black/80 text-white text-xs px-3 py-1 rounded-full uppercase tracking-widest font-bold">
        Lista de Reproducción
      </div>
    )}
  </div>
</div>

<script define:vars={{ id }}>
  document.addEventListener('DOMContentLoaded', function () {
    const container = document.getElementById(`yt-lite-${id}`);
    
    if (container) {
      container.addEventListener('click', function () {
        const ytId = container.getAttribute('data-yt-id');
        const type = container.getAttribute('data-yt-type');
        const title = container.getAttribute('data-title');
        
        // Construcción dinámica de la URL según el tipo
        let embedPath = type === 'playlist' 
          ? `videoseries?list=${ytId}` 
          : `${ytId}?autoplay=1`;
        
        const iframe = document.createElement('iframe');
        iframe.className = 'w-full h-full absolute inset-0';
        iframe.src = `https://www.youtube.com/embed/${embedPath}&rel=0&modestbranding=1`;
        iframe.title = title;
        iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
        iframe.allowFullscreen = true;
        iframe.frameBorder = '0';
        
        container.innerHTML = '';
        container.appendChild(iframe);
      });
    }
  });
</script>
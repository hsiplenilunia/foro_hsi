  ---
  import { Image } from "astro:assets";
  import Button from "../Button.astro";

  //const sectionStyles = `landing-section bg-purple h-screen w-screen text-center overflow-hidden overflow-y-hidden relative`;
  const sectionStyles = `landing-section bg-bg-white w-screen flex items-center justify-center pt-16 px-8 relative`;
  ---

  
<!-- <section class="relative w-full overflow-hidden py-10 px-6 md:px-12 min-h-[450px] bg-white">-->

<section class="relative w-full overflow-hidden py-10 px-6 md:px-12 min-h-[450px] bg-white
          md:bg-[url('/bg_concurso_2026.svg')] md:bg-no-repeat 
          md:bg-[length:auto_100%] md:bg-right">

  <div class="hidden md:block">
     <h2 class="text-3xl font-bold font-size:32px text-gray-800">Concurso de Trabajos Libres:<br>
      <div class="bg-gray-100 rounded-full px-6 py-1">
    <span class="bg-gradient-concurso bg-clip-text text-transparent font-extrabold italic text-3xl md:text-4xl"> Prevención de escaras</span>
    <div class="bg-gray-100 rounded-full px-6 py-1">
           <span class="bg-gradient-concurso bg-clip-text text-transparent font-extrabold italic text-3xl md:text-4xl">
             e infecciones de heridas
           </span>
         </div>
</h2><br>
  </div>
     </div>
     <div class="hidden md:block flex flex-row gap-4 w-full justify-start items-center">

        <a href="https://docs.google.com/forms/d/e/1FAIpQLSd7eKjd95ZBHlT3GroRk2lhezZS7Y_STZHOnA5Q8VNDtYKHYg/viewform?usp=sharing&ouid=108928240711952588233" class="registro-checkout--button"
         style="background: #0AB1E5; color: #000; display: flex; align-items: center; justify-content: center; width: 200px; height: 32px; border-radius: 32px; text-transform: capitalize; text-decoration: none; font-weight: 400; font-size: 16px; font-bold; transition: all 0.3s ease;"
         onmouseover="this.style.background='#1D5168'; this.style.color='#fff'; this.style.fontWeight='900'; this.style.transform='scale(1.03)';"
         onmouseout="this.style.background='#0AB1E5'; this.style.color='#000'; this.style.fontWeight='400'; this.style.transform='scale(1)';">Registro concurso</a><br>
  </div>
         <div class="hidden md:block flex flex-row gap-4 w-full justify-start items-center">
        <a href="https://docs.google.com/document/d/1SnlxwnpopZM9UVwbhURhBPzo0z690vXG/edit" class="bases-checkout--button"
         style="background: #D9D9D9; color: #000; display: flex; align-items: center; justify-content: center; width: 200px; height: 32px; border-radius: 32px; text-transform: capitalize; text-decoration: none; font-weight: 400; font-size: 16px; font-bold; transition: all 0.3s ease;"
         onmouseover="this.style.background='#D9D9D9'; this.style.color='#0AB1E5'; this.style.fontWeight='900'; this.style.transform='scale(1.03)';"
         onmouseout="this.style.background='#D9D9D9'; this.style.color='#000'; this.style.fontWeight='400'; this.style.transform='scale(1)';">Bases del Concurso</a>
     </div>


  <div class="md:hidden">
     <div class="w-full h-auto mb-6">
        <img src="/bg_concurso_mobile.svg" alt="Concurso Trabajos Libres" class="w-full object-cover">
     </div>

     <div class="px-6 text-center">
        <h2 class="text-2xl font-bold mb-6">
           Concurso de Trabajos Libres:<br>
           <span class="bg-gradient-concurso bg-clip-text text-transparent">
             Prevención de escaras e infecciones de heridas
           </span>
        </h2>

        <div class="flex flex-col gap-4 w-full max-w-[280px] mx-auto">
           <a href="https://docs.google.com/forms/d/e/1FAIpQLSd7eKjd95ZBHlT3GroRk2lhezZS7Y_STZHOnA5Q8VNDtYKHYg/viewform?usp=sharing&ouid=108928240711952588233" class="registro-checkout--button"
         style="background: #0AB1E5; color: #000; display: flex; align-items: center; justify-content: center; width: 200px; height: 32px; border-radius: 32px; text-transform: capitalize; text-decoration: none; font-weight: 400; font-size: 16px; font-bold; transition: all 0.3s ease;"
         onmouseover="this.style.background='#1D5168'; this.style.color='#fff'; this.style.fontWeight='900'; this.style.transform='scale(1.03)';"
         onmouseout="this.style.background='#0AB1E5'; this.style.color='#000'; this.style.fontWeight='400'; this.style.transform='scale(1)';">Registro concurso</a>

           <div class="flex flex-col gap-4 w-full max-w-[280px] mx-auto">
           <a href="https://docs.google.com/document/d/1SnlxwnpopZM9UVwbhURhBPzo0z690vXG/edit" class="bases-checkout--button"
         style="background: #D9D9D9; color: #000; display: flex; align-items: center; justify-content: center; width: 200px; height: 32px; border-radius: 32px; text-transform: capitalize; text-decoration: none; font-weight: 400; font-size: 16px; font-bold; transition: all 0.3s ease;"
         onmouseover="this.style.background='#D9D9D9'; this.style.color='#0AB1E5'; this.style.fontWeight='900'; this.style.transform='scale(1.03)';"
         onmouseout="this.style.background='#D9D9D9'; this.style.color='#000'; this.style.fontWeight='400'; this.style.transform='scale(1)';">Bases del Concurso</a>
        </div>
     </div>
  </div>

</section>
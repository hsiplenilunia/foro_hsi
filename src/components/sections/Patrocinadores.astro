---
// PatrocinadoresSlider.astro
const logos = [
  { src: "/logos/asp.webp", alt: "Asp" },
  { src: "/logos/biomerieux.webp", alt: "Biomerieux" },
  { src: "/logos/logo_Intima.png", alt: "Íntima" },
  { src: "/logos/logo_exeltis.png", alt: "Exeltis" },
  { src: "/logos/Logo TurnOververde .png", alt: "Turnover" },
  { src: "/logos/LALA logo patrocinador.png", alt: "Lala" },
  { src: "/logos/Astellas Logo Patrocinador.png", alt: "Astellas" },
  { src: "/logos/cumlaude-removebg-preview.webp", alt: "Cumlaude" },
  { src: "/logos/Logo_Koltin-01ok.png", alt: "Koltin" },
  { src: "/logos/moore.png", alt: "Moore" },
  { src: "/logos/lykadfinal.webp", alt: "Lykad" },
  { src: "/logos/granagard.webp", alt: "Granagard" },
  { src: "/logos/logo_vivien.webp", alt: "Vivien" },
  { src: "/logos/logo_libdo.webp", alt: "Libdo" },
  { src: "/logos/Natura.png", alt: "Natura" },
  { src: "/logos/logo_botanical_wisdom_ok.png", alt: "Botanical Wisdom" },
  { src: "/logos/logo_therbal.png", alt: "Therbal" },
  { src: "/logos/koi_cafe_and_catering.webp", alt: "KOI Cafe" },
  { src: "/logos/logo_krikketi.png", alt: "KRIKKETI" },
  { src: "logos/SaludAureaPatrocinador300dpi (1).webp", alt: "Salud Áurea" },
  { src: "logos/logo_holiherb.png", alt: "Holiherb" },
];

// Dividi en dos grupos para las dos filas
const mitad = Math.ceil(logos.length / 2);
const filaUno = logos.slice(0, mitad);
const filaDos = logos.slice(mitad);
---

<section class="w-full py-10 overflow-hidden bg-white" id="patrocinadores">
  <h2 class="text-center text-2xl font-bold uppercase tracking-widest text-[#204356] mb-8">
    Patrocinadores
  </h2>

  <!-- Fila 1: izquierda → -->
  <div class="relative flex overflow-hidden mb-6 [mask-image:linear-gradient(to_right,transparent,white_10%,white_90%,transparent)]">
    <div class="marquee-row marquee-left flex gap-12 w-max">
      {[...filaUno, ...filaUno].map((logo) => (
        <div class="flex-shrink-0 flex items-center justify-center h-16 w-32">
          <img src={logo.src} alt={logo.alt} class="h-12 w-auto max-w-[120px] object-contain grayscale hover:grayscale-0 transition-all duration-300" loading="lazy" />
        </div>
      ))}
    </div>
  </div>
<h2 class="text-center text-2xl font-bold uppercase tracking-widest text-[#204356] mb-8">
    Patrocinadores
  </h2>
  <!-- Fila 2: derecha ← (sentido contrario) -->
  <div class="relative flex overflow-hidden [mask-image:linear-gradient(to_right,transparent,white_10%,white_90%,transparent)]">
    <div class="marquee-row marquee-right flex gap-12 w-max">
      {[...filaDos, ...filaDos].map((logo) => (
        <div class="flex-shrink-0 flex items-center justify-center h-16 w-32">
          <img src={logo.src} alt={logo.alt} class="h-12 w-auto max-w-[120px] object-contain grayscale hover:grayscale-0 transition-all duration-300" loading="lazy" />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .marquee-row {
    animation-timing-function: linear;
    animation-iteration-count: infinite;
  }

  .marquee-left {
    animation-name: scrollLeft;
    animation-duration: 30s;
  }

  .marquee-right {
    animation-name: scrollRight;
    animation-duration: 30s;
  }

  @keyframes scrollLeft {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes scrollRight {
    0%   { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  /* Pausa al hacer hover sobre toda la sección */
  section:hover .marquee-row {
    animation-play-state: paused;
  }
</style>
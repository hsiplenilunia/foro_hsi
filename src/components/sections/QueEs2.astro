---
import { Image } from "astro:assets";
import pleniluniaLogo from "../../assets/Hospi-con-texto-correcion-2.png";
import YouTubePlayer from "../YouTubePlayer.astro";

const sectionStyles = `landing-section bg-white w-full py-20 px-4 relative`;

// Definimos el ID de la lista de reproducción
const playlistId = "PL-8jwCqR-sc0RZYJ1-SrbVyWck8ZEsTfT";

/** 
 * Configuramos la URL con parámetros de experiencia de usuario:
 * - list: El ID de tu playlist.
 * - rel=0: Para que al final no recomiende videos de otros canales.
 * - modestbranding=1: Para un look más limpio (menos logos de YouTube).
 */
const playlistUrl = `https://www.youtube.com/embed/videoseries?list=${playlistId}&rel=0&modestbranding=1`;

const title = "Lista de Reproducción - VI Foro Internacional 2026";
---

<section class={sectionStyles} data-header-color={`white`} id="playlist-section">
  <div class="container mx-auto z-10 relative">
    <div class="flex flex-col md:flex-row items-center gap-12">
      
      <!-- Contenedor del Reproductor -->
      <div class="w-full lg:w-[42%] order-2 lg:order-1">
                  <!-- Inyectamos la URL de la lista en el componente -->
       <div class="group relative shadow-xl rounded-2xl overflow-hidden bg-slate-100 border-4 border-white">
          <YouTubePlayer url={playlistUrl} title="VI Foro 2026 Playlist" />
        </div>

   
        <p class="mt-4 text-blue-text font-semibold flex items-center gap-2">
          <span class="flex h-3 w-3 rounded-full bg-blue-500 animate-pulse"></span>
          Reproduciendo: Foro Hospitales sin Infecciones
        </p>
      </div>

      <!-- Contenedor de Información Lateral -->
      <div class="w-full lg:w-[50%] order-1 lg:order-2">

        <div class="relative">
          <div class="absolute -top-10 -right-10 w-64 h-64 bg-blue-50 rounded-full blur-3xl opacity-50 -z-10"></div>
        <Image
          src={pleniluniaLogo}
          alt="Infografia Hospitales sin Infecciones"
          width={800}
          class="w-full h-auto drop-shadow-2xl rounded-xl transition-all duration-500 hover:scale-[1.02]"
          loading="eager"

        />
        <div class="space-y-4">
          <p class="text-black-text text-lg leading-relaxed">
            <strong>Comparte, aprende y relaciónate </strong>con los mejores
            especialistas en vigilancia epidemiológica, infectología, calidad y
            seguridad del paciente.
          </p>
          <div class="bg-gray-100 p-4 rounded-lg border-l-4 border-blue-600 text-sm text-left">
            <ul class="space-y-2">
              <li>• Marco Regulatorio</li>
              <li>• Defensa Legal</li>
              <li>• Colaboración Multidisciplinaria</li>
              <li>• Impacto en Estancias</li>
              <li>• Seguridad del Paciente</li>
            </ul>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

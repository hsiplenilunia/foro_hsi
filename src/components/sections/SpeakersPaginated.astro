---
// SpeakersPaginated.astro
const speakers = [
  { src: "https://res.cloudinary.com/difrqz0ke/image/upload/v1752861847/speaker_santiago_march_csvoed.webp", alt: "Santiago March" },
  { src: "https://res.cloudinary.com/difrqz0ke/image/upload/v1752861847/speakerr_roxana_trejo_forhdu.webp", alt: "Roxana Trejo" },
  { src: "https://res.cloudinary.com/difrqz0ke/image/upload/v1752861847/speaker_maribel_ramirez_yavpyb.webp", alt: "Maribel Ramírez" },
  { src: "https://res.cloudinary.com/difrqz0ke/image/upload/v1752861847/speaker_luis_galindo_zb9iyx.webp", alt: "Luis Galindo" },
  { src: "https://res.cloudinary.com/difrqz0ke/image/upload/v1752861847/speaker_hector_valle_comdzp.webp", alt: "Héctor Valle" },
  { src: "https://res.cloudinary.com/difrqz0ke/image/upload/v1752861846/speaker_fabiola_casas_ohhgal.webp", alt: "Fabiola Casas" },
  { src: "https://res.cloudinary.com/difrqz0ke/image/upload/v1752861846/speaker_fabiana_zepeda_e7vexy.webp", alt: "Fabiana Zepeda" },
  { src: "https://res.cloudinary.com/difrqz0ke/image/upload/v1752861846/speaker_eduardo_gonzalez_zuyzpy.webp", alt: "Eduardo González" },
  { src: "https://res.cloudinary.com/difrqz0ke/image/upload/v1752861846/speaker_eric_ochoa_loz2gx.webp", alt: "Eric Ochoa" },
  { src: "https://res.cloudinary.com/difrqz0ke/image/upload/v1752861846/speaker_celia_mercedes_vpqdsc.webp", alt: "Celia Mercedes" },
  { src: "https://res.cloudinary.com/difrqz0ke/image/upload/v1752861846/speaker_daniela_de_la_rosa_kbdhxe.webp", alt: "Daniela de la Rosa" },
  { src: "https://res.cloudinary.com/difrqz0ke/image/upload/v1752861845/speaker_alejandro_macias_egwdei.webp", alt: "Alejandro Macías" },
  { src: "https://res.cloudinary.com/difrqz0ke/image/upload/v1752865731/speaker_juanita_jimenez_ygqzip.webp", alt: "Juanita Jiménez" },


];

// Una Sola Fila

const filaUno = speakers.slice(0);
---

<section class="w-full py-10 overflow-hidden bg-white" id="speakers">
  <h2 class="text-center text-3xl font-bold uppercase tracking-widest text-[#204356] mb-8">
    Speakers
    <br>
  </h2>

  <!-- Fila 1: izquierda → -->
  <div class="relative flex overflow-hidden mb-6 [mask-image:linear-gradient(to_right,transparent,white_10%,white_90%,transparent)] py-6">
    <div class="marquee-row marquee-left flex gap-12 w-max">
      {[...filaUno, ...filaUno].map((logo) => (
        <div class="flex-shrink-0 flex items-center justify-center h-64 w-64">
          <img src={logo.src} alt={logo.alt} class="h-50 w-auto max-w-[120px] object-contain hover:scale-110 transition-all duration-300" loading="lazy" />
        </div>
      ))}
    </div>
  </div>

</section>

<style>
  .marquee-row {
    animation-timing-function: linear;
    animation-iteration-count: infinite;
  }

  .marquee-left {
    animation-name: scrollLeft;
    animation-duration: 30s;
  }

  .marquee-right {
    animation-name: scrollRight;
    animation-duration: 30s;
  }

  @keyframes scrollLeft {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes scrollRight {
    0%   { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  /* Pausa al hacer hover sobre toda la sección */
  section:hover .marquee-row {
    animation-play-state: paused;
  }
</style>
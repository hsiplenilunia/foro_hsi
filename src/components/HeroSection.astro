---
import { Image } from "astro:assets";
import Button from "./Button.astro";
import hsiBg from "../assets/hsi_bg.png";
import heroLogo from "../assets/hero-logo.png";
import heroLogoMobile from "../assets/hero-logo-mobile-min.png";
import heroWoman from "../assets/hero-woman.png";
import msLogo from "../assets/logo_cnsp.png";
import msLogoMedicaSur from "../assets/medica_sur.png";
import HeroSlider from "./react/HeroSlider.tsx";
import DescargarAgendaButton from "./atoms/DescargarAgendaButton.astro";

const sectionStyles = `landing-section md:min-h-screen bg-light-gray w-screen text-center overflow-hidden relative pb-24 md:pb-0`;
---

<section class={sectionStyles} data-header-color={`light-gray`} id="inicio">

    <!-- Background -->
  <div
    class="absolute inset-0 z-0 bg-no-repeat bg-cover bg-center pointer-events-none"
    style="background-image: url('/hero-bg.png');"
    aria-hidden="true"
  ></div>

  <!-- Desktop Layout -->
  <div class="flex flex-col xl:mt-6">
    <div class="hidden lg:flex flex-row justify-between items-start grow px-0 pl-[5%] pr-[5%] pt-32 z-30 relative min-h-[500px]">

     <!-- LEFT: Slider + Logo -->
<div class="flex-1 h-full flex flex-col items-start gap-2">
  <HeroSlider client:idle />
  <div class="flex flex-col items-start mt-4 w-full gap-2">
    <span class="px-4 py-1 rounded-[5px] text-white font-semibold text-sm shadow bg-gradient-hsi">
      AVAL ACADÉMICO
    </span>
    <Image
      src={msLogo}
      alt="CNSP"
      class="h-24 w-auto"
      width={280}
      height={280}
      loading="lazy"
      decoding="async"
      format="png"
      quality={80}
    />
  </div>
</div>
<!-- fin de lado izquierdo -->

     <!-- Lado Derecho: Textos -->
<div class="flex flex-col w-[50vw] items-center max-w-[50vw] space-y-4 mb-5 h-full text-center px-8">
<!-- Línea ondulada decorativa -->
 <br>
  <img src="/wave-line.svg" alt="" class="w-[142px] md:w-[280px]" aria-hidden="true" />
  <!-- VI Foro 2026 -->
  <h1 class="text-left">
  <span class="text-6xl block bg-gradient-hsi bg-clip-text text-transparent italic font-black uppercase leading-tight pb-1">VI</span>
  <span class="text-6xl block bg-gradient-hsi bg-clip-text text-transparent italic font-black uppercase leading-tight py-1">Foro</span>
  <span class="text-6xl block bg-gradient-hsi bg-clip-text text-transparent italic font-black uppercase leading-tight pt-1">2026</span>
</h1>

  <!-- Línea ondulada decorativa -->
  <img src="/wave-line.svg" alt="" class="w-[142px] md:w-[280px]" aria-hidden="true" />

<div class="bg-[#204356] rounded-full px-8 py-3 w-full max-w-[575px] h-12 flex items-center justify-center">
    <p class="text-white font-bold italic leading-[114.9%] tracking-normal text-center whitespace-nowrap"
     style="font-size: clamp(18px, 2.5vw, 36px);">
    El desafío de las Infecciones</p>
</div>

  <!-- Subtítulo verde en cursiva -->
  <h3 class="text-green-600 italic font-normal text-xl leading-snug text-center">
    <span>"UNA SOLA SALUD" ANTE LA</span><br />
    <span>RESISTENCIA ANTIMICROBIANA"</span>
  </h3>

  <!-- FONDO DEGRADADO "EVENTO GRATUITO" -->
  <div>
  <span class="px-6 py-2 rounded-full text-white font-bold tracking-widest shadow bg-gradient-hsi whitespace-nowrap"
        style="font-size: clamp(12px, 1.2vw, 16px);">
    EVENTO GRATUITO
  </span>
  </div>

  <!-- Fecha del foro  -->
  <p class="text-3xl font-black text-blue-text tracking-wide text-center">
    27 Y 28 DE AGOSTO, 2026
  </p>

  <!-- Sede + línea ondulada decorativa -->
  <div class="flex flex-col items-center w-full">
    <p class="text-gray-700 text-lg font-normal tracking-widest text-center text-blue-text">
      SEDE | <strong class="font-extrabold">Auditorio Médica Sur</strong>
    </p>
    <img src="/wave-line.svg" alt="" class="w-68 mt-2 opacity-50" aria-hidden="true" />
  </div>

  <!-- MédicaSur logo + texto institucional -->
  <div class="flex items-center gap-2 mt-2">
    <Image
      src={msLogoMedicaSur}
      alt="Médica Sur"
      class="h-12 w-auto"
      width={200}
      height={200}
      loading="lazy"
      format="png"
      quality={100}
    />
    <!-- Separador vertical -->
    <div class="w-px h-14 bg-gray-400"></div>
    <!-- Texto institucional -->
    <p class="text-gray-700 font-bold text-blue-text italic text-base leading-snug text-left max-w-[180px]">
      Institución sede comprometida<br/>con el combate a las infecciones
    </p>
  </div>
</div>
<!-- Termina Lado derecho -->
</div>
<!-- Fin lg:flex -->
</div>
<!-- Fin desktop layout -->

  <!-- Mobile Layout -->
  <div class="lg:hidden flex flex-col items-center text-center px-6 pt-40 z-30 relative h-full">
    <h1 class="text-black text-3xl font-black uppercase">
      <span class="text-6xl block bg-gradient-to-r from-gradient-start via-gradient-center to-gradient-end bg-clip-text text-transparent font-black uppercase leading-none">VI</span>
      <span class="text-6xl block bg-gradient-to-r from-gradient-start via-gradient-center to-gradient-end bg-clip-text text-transparent font-black uppercase leading-none">Foro</span>
      <span class="text-6xl block bg-gradient-to-r from-gradient-start via-gradient-center to-gradient-end bg-clip-text text-transparent font-black uppercase leading-none">2026</span>
    </h1>

    <Image
      src={heroLogoMobile}
      alt="Doctores"
      class="w-[200px] mt-4"
      loading="eager"
      fetchpriority="high"
      width={320}
      format="png"
      quality={80}
    />

    <h3 class="text-green-600 flex flex-col w-full items-center justify-center leading-3 font-normal text-2xl mt-3 mb-6">
      <span>"UNA SOLA SALUD" ANTE LA</span><br/>
      <span>RESISTENCIA MICROBIANA</span><br/>
    </h3>

    <div class="bg-gradient-to-r from-gradient-start via-gradient-center to-gradient-end rounded-[20px] px-6 py-2 inline-block mb-3">
      <p class="text-white font-extrabold uppercase text-xl leading-tight tracking-wide text-left">
        El desafío de las infecciones
      </p>
    </div>

    <p class="text-blue-text text-3xl font-bold">
      27 Y 28 DE <br />AGOSTO, 2026
    </p>

    <div class="flex flex-col items-center w-full mt-2">
      <p class="text-blue-text text-xl text-center font-normal tracking-wide">
        SEDE | Auditorio del <br /><strong class="font-extrabold">Hospital Médica Sur</strong>
      </p>
        <img src="/wave-line.svg" alt="" class="w-48 mt-2 opacity-50" aria-hidden="true" />
    </div>

    <span class="px-4 py-1 rounded-full text-white font-semibold text-base shadow bg-gradient-to-r from-gradient-start via-gradient-center to-gradient-end mt-10 mb-2">
      AVAL ACADÉMICO
    </span>
    <Image
      src={msLogo}
      alt="Médica Sur"
      class="h-24 w-auto"
      width={200}
      height={60}
      loading="lazy"
      decoding="async"
      format="png"
      quality={80}
    />
  </div>
  <!-- END Mobile Layout -->
</section>
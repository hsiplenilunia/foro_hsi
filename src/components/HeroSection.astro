---
import { Image } from "astro:assets";
import Button from "./Button.astro";
import heroLogoMobile from "../assets/hero-logo-mobile.png";
import VIForoHsi from "../assets/VIForo2026.svg";
import msLogo from "../assets/logo_cnsp.svg";
import msLogoMedicaSur from "../assets/medica-sur.svg";
import HeroSlider from "./react/HeroSlider.tsx";
import DescargarAgendaButton from "./atoms/DescargarAgendaButton.astro";

const sectionStyles = `landing-section md:min-h-screen bg-light-white w-screen text-center overflow-hidden relative pb-24 md:pb-0`;
---

<section class={sectionStyles} data-header-color={`light-white`} id="inicio">

    <!-- Fondo del home -->
  <div
    class="absolute inset-0 z-0 bg-no-repeat bg-cover bg-center pointer-events-none"
    style="background-image: url('/hero-bg.png');"
    aria-hidden="true"></div>

  <!-- Desktop Layout -->
  <div class="flex flex-col xl:mt-6">
    <div class="hidden lg:flex flex-row justify-between items-start grow px-0 pl-[5%] pr-[5%] pt-32 z-30 relative min-h-[500px]">

     <!-- LEFT: Slider + Logo -->
<div class="flex-1 h-full flex flex-col items-start gap-2">
  <HeroSlider client:idle />

</div>
<!-- fin de lado izquierdo -->

     <!-- Lado Derecho: Textos -->
<div class="flex flex-col w-[50vw] items-left max-w-[50vw] space-y-4 mb-5 h-full px-8">

  <!-- Lado Derecho: Textos -->
<div class="flex flex-col w-full md:w-[50vw] items-start max-w-full md:max-w-[50vw] space-y-4 mb-5 h-full px-8">

  <!-- Contenedor para Logo + Botón (Fila en Desktop) -->
  <div class="flex flex-col md:flex-row md:items-center gap-6">
    <!-- VI Foro 2026 -->
    <Image
      src={VIForoHsi}
      alt="VI Foro"
      class="h-auto w-40 md:w-46"
      width={182}
      height={164}
      loading="lazy"
      decoding="async"
      format="svg"
      quality={80}
    />

    <!-- Botón de Registro -->
    <a 
      href="https://luma.com/event/evt-zj3SHeoDaiIDIci" 
      class="luma-checkout--button flex items-center justify-center bg-gradient-hsi text-white font-extrabold transition-all duration-300 uppercase tracking-wider shadow-md hover:shadow-xl hover:brightness-110 active:scale-95
      /* Mobile: Botón más presente */
      w-full py-4 text-xl rounded-full
      /* Desktop: Medidas Figma (169x46px) */
      md:w-[169px] md:h-[46px] md:text-[14px] md:py-0 md:rounded-full whitespace-nowrap"
      data-luma-action="checkout" 
      data-luma-event-id="evt-zj3SHeoDaiIDIci"
    >
      REGISTRO
    </a>
  </div>

</div>

<div class="bg-[#204356] rounded-full px-8 py-3 w-full max-w-[575px] h-12 flex items-center justify-center">
    <p class="text-white font-bold italic leading-[114.9%] tracking-normal text-center whitespace-nowrap"
     style="font-size: clamp(18px, 2.5vw, 36px);">
    El desafío de las Infecciones</p>
</div>

  <!-- Subtítulo verde en cursiva -->
  <h3 class="text-green-600 font-medium italic text-xl leading-snug text-justify">
    <span>“UNA SOLA SALUD” ANTE LA</span><br />
    <span>RESISTENCIA ANTIMICROBIANA</span>
  </h3>

  <!-- FONDO DEGRADADO "EVENTO GRATUITO" -->
  <div class="text-justify">
  <span class="px-6 py-2 rounded-[5px] text-white font-bold tracking-widest shadow bg-gradient-hsi whitespace-nowrap"
        style="font-size: clamp(12px, 1.2vw, 18px);">
    EVENTO GRATUITO
  </span>
  </div>

  <!-- Fecha del foro  -->
  <p class="text-3xl font-black text-blue-text tracking-wide text-justify">
    27 Y 28 DE AGOSTO, 2026
  </p>

  <!-- Sede + línea ondulada decorativa -->
  <div class="flex flex-col items-justify w-full">
    <p class="text-gray-700 text-lg font-thin tracking-widest text-justify text-blue-text">
      SEDE | <strong class="font-extrabold">Auditorio Médica Sur</strong>
    </p>
    <br>
   <img src="/wave-line.svg" alt="" class="w-[142px] md:w-[350px]" aria-hidden="true" />
  </div>

  <!-- MédicaSur logo + texto institucional -->
  <div class="flex items-center gap-2 mt-[14px]">
    <Image
      src={msLogoMedicaSur}
      alt="Médica Sur"
      class="h-12 w-auto"
      width={224.6}
      height={52}
      loading="lazy"
      format="svg"
      quality={80}
    />
    <!-- Separador vertical -->
    <div class="w-px h-14 bg-gray-400"></div>
    <!-- Texto institucional -->
    <p class="font-bold text-blue-text italic text-base leading-snug text-justify max-w-[280px]">
      Institución sede comprometida<br/>con el combate a las infecciones
    </p>
  </div>

<!--Aval Acaemico, degradado + logo -->
<div class="flex flex-row items-center gap-6 mt-6">
  
  <!-- Etiqueta Aval Académico -->
   <span class="px-6 py-2 rounded-[5px] text-white font-bold tracking-widest shadow bg-gradient-hsi whitespace-nowrap"
        style="font-size: clamp(12px, 1.2vw, 18px);">
    AVAL ACADÉMICO
  </span>

  <!-- Logo CNSP -->
  <Image
    src={msLogo}
    alt="CNSP"
    class="h-32 w-auto" 
    width={165}
    height={165}
    loading="lazy"
    format="svg"
    quality={100}
  />
  
</div>
<!-- Termina Lado derecho -->
</div>
<!-- Fin lg:flex -->
</div>
<!-- Fin desktop layout -->



  <!-- Mobile Layout -->
<div
  class="absolute inset-0 z-0 bg-no-repeat bg-cover bg-center pointer-events-none"
  style="background-image: url('/bg_home_mobile.png');"
  aria-hidden="true">
</div>

<div class="lg:hidden flex flex-col items-center text-center px-6 pt-32 z-30 relative h-full">

  <!-- VI Foro 2026 mobile -->
  <Image
    src={VIForoHsi}
    alt="VI Foro"
    class="w-[140px] h-auto"
    width={182}
    height={164}
    loading="lazy"
    decoding="async"
    format="svg"
    quality={90}
  />

  <!-- EVENTO GRATUITO -->
  <div class="mt-3 mb-2">
    <span class="px-6 py-2 rounded-[5px] text-white font-bold tracking-widest shadow bg-gradient-hsi text-sm">
      EVENTO GRATUITO
    </span>
  </div>

  <!-- Imagen doctores solo mobile -->
<Image
  src={heroLogoMobile}
  alt="Doctores"
  class="w-[290px] h-auto my-4 object-contain"
  loading="eager"
  fetchpriority="high"
  width={290}
  height={400}
  format="png"
  quality={90}
/>

  <!-- Badge ancho completo y texto escalable -->
  <div class="bg-[#204356] rounded-full px-6 py-3 w-full flex items-center justify-center">
    <p
      class="text-white font-bold italic leading-snug tracking-normal text-center"
      style="font-size: clamp(16px, 5.1vw, 36px);">
      El desafío de las Infecciones
    </p>
  </div>

  <!-- Subtítulo Mobile -->
  <h3 class="text-green-600 mt-3 font-medium italic text-lg leading-snug text-center">
    <span>"UNA SOLA SALUD" ANTE LA</span><br />
    <span>RESISTENCIA ANTIMICROBIANA</span>
  </h3>

  <!-- Fecha mobile -->
  <p class="text-blue-text mt-3 text-3xl font-bold">
    27 Y 28 DE AGOSTO, 2026
  </p>

  <!-- SEDE Mobile-->
  <div class="flex flex-col items-center w-full mt-2">
    <p class="text-blue-text text-lg text-center font-thin tracking-wide">
      SEDE | <strong class="font-extrabold">Auditorio Médica Sur</strong>
    </p>
  </div>

  <!-- MédicaSur logo + texto — columna centrada -->
  <div class="flex flex-col items-center mt-4 gap-2">
    <Image
      src={msLogoMedicaSur}
      alt="Médica Sur"
      class="h-14 w-auto"
      width={200}
      height={60}
      loading="lazy"
      format="svg"
      quality={100}
    />
    <p class="font-bold italic text-blue-text  text-center text-base leading-snug">
      Institución sede comprometida<br />con el combate a las infecciones
    </p>
  </div>

  <!-- AVAL ACADÉMICO -->
  <div class="mt-5">
    <span class="px-6 py-2 rounded-[5px] text-white font-bold tracking-widest shadow bg-gradient-hsi text-sm">
      AVAL ACADÉMICO
    </span>
  </div>

  <!-- Logo CNSP -->
  <Image
    src={msLogo}
    alt="CNSP"
    class="h-32 w-auto mt-3 mb-8"
    width={132}
    height={132}
    loading="lazy"
    format="svg"
    quality={100}
  />

   <!-- Botón de Registro -->
    <a 
      href="https://luma.com/event/evt-zj3SHeoDaiIDIci" 
      class="luma-checkout--button flex items-center justify-center bg-gradient-hsi text-white font-extrabold transition-all duration-300 uppercase tracking-wider shadow-md hover:shadow-xl hover:brightness-110 active:scale-95
      /* Mobile: Botón más presente */
      w-full py-4 text-xl rounded-full
      /* Desktop: Medidas Figma (169x46px) */
      md:w-[169px] md:h-[46px] md:text-[14px] md:py-0 md:rounded-full whitespace-nowrap"
      data-luma-action="checkout" 
      data-luma-event-id="evt-zj3SHeoDaiIDIci"
    >
      REGISTRO
    </a>

</div>
<!-- END Mobile Layout -->
</section>
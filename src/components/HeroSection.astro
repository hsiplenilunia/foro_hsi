---
import { Image } from "astro:assets";
import Button from "./Button.astro";
import hsiBg from "../assets/hsi_bg.png";
import heroLogo from "../assets/hero-logo.png";
import heroLogoMobile from "../assets/hero-logo-mobile.png";
import heroWoman from "../assets/hero-woman.png";
import msLogo from "../assets/logo_cnsp.png";
import HeroSlider from "./react/HeroSlider.tsx";
import DescargarAgendaButton from "./atoms/DescargarAgendaButton.astro";

const sectionStyles = `landing-section md:min-h-screen bg-light-gray w-screen text-center overflow-hidden relative pb-24 md:pb-0`;
---

<section class={sectionStyles} data-header-color={`light-gray`} id="inicio">

  <!-- Desktop Layout -->
  <div class="flex flex-col xl:mt-6">
    <div class="hidden lg:flex flex-row justify-between items-start grow px-0 pl-[5%] pr-[5%] pt-32 z-30 relative min-h-[500px]">

     <!-- LEFT: Slider + Logo -->
<div class="flex-1 h-full flex flex-col items-start gap-2">
  <HeroSlider client:idle />
  <div class="flex flex-col items-start mt-4 w-full gap-2">
    <span class="px-4 py-1 rounded-full text-white font-semibold text-sm shadow bg-gradient-to-r from-[#3bb3c3] to-[#6ec06b]">
      AVAL ACADÉMICO
    </span>
    <Image
      src={msLogo}
      alt="CNSP"
      class="h-24 w-auto"
      width={280}
      height={280}
      loading="lazy"
      decoding="async"
      format="png"
      quality={80}
    />
  </div>
</div>

     <!-- RIGHT: Text content -->
<div class="flex flex-col w-[20vw] items-center max-w-[50vw] space-y-4 mb-5 h-full text-center px-8">

  <!-- VI Foro 2026 -->
  <h1 class="text-center">
    <span class="text-6xl block bg-gradient-to-r from-gradient-start via-gradient-center to-gradient-end bg-clip-text text-transparent font-black uppercase leading-none">VI</span>
    <span class="text-6xl block bg-gradient-to-r from-gradient-start via-gradient-center to-gradient-end bg-clip-text text-transparent font-black uppercase leading-none">Foro</span>
    <span class="text-6xl block bg-gradient-to-r from-gradient-start via-gradient-center to-gradient-end bg-clip-text text-transparent font-black uppercase leading-none">2026</span>
  </h1>

  <!-- Línea ondulada decorativa (puedes usar un SVG o imagen) -->
  <img src="/wave-line.svg" alt="" class="w-24 opacity-70" aria-hidden="true" />

  <!-- Badge oscuro con texto en cursiva -->
  <div class="bg-[#204356] rounded-[20px] px-6 py-3 w-full">
    <p class="text-white font-extrabold italic text-2xl leading-tight tracking-wide text-center">
      El desafío de las Infecciones
    </p>
  </div>

  <!-- Subtítulo verde en cursiva -->
  <h3 class="text-green-600 italic font-semibold text-xl leading-snug text-center">
    <span>"UNA SOLA SALUD" ANTE LA</span><br />
    <span>RESISTENCIA ANTIMICROBIANA</span>
  </h3>

  <!-- Badge outline "EVENTO GRATUITO" -->
  <div class="border-2 border-green-500 rounded-full px-5 py-1 inline-block">
    <p class="text-green-600 font-bold uppercase text-sm tracking-widest">
      Evento Gratuito
    </p>
  </div>

  <!-- Fecha -->
  <p class="text-3xl font-black text-gray-800 tracking-wide text-center">
    27 Y 28 DE AGOSTO, 2026
  </p>

  <!-- Sede + línea ondulada -->
  <div class="flex flex-col items-center w-full">
    <p class="text-gray-700 text-lg font-normal tracking-widest text-center">
      SEDE | <strong class="font-extrabold">Auditorio Médica Sur</strong>
    </p>
    <img src="/wave-line.svg" alt="" class="w-48 mt-2 opacity-60" aria-hidden="true" />
  </div>

  <!-- MédicaSur logo + texto institucional en fila -->
  <div class="flex items-center gap-4 mt-2">
    <Image
      src={msLogoMedicaSur}
      alt="Médica Sur"
      class="h-16 w-auto"
      width={160}
      height={64}
      loading="lazy"
      format="webp"
      quality={80}
    />
    <!-- Separador vertical -->
    <div class="w-px h-14 bg-gray-400"></div>
    <!-- Texto institucional -->
    <p class="text-gray-700 font-bold italic text-base leading-snug text-left max-w-[180px]">
      Institución sede comprometida<br />con el combate a las infecciones
    </p>
  </div>

</div>

  <!-- Mobile Layout -->
  <div class="lg:hidden flex flex-col items-center text-center px-6 pt-40 z-30 relative h-full">
    <h1 class="text-black text-3xl font-black uppercase">
      <span class="text-6xl block bg-gradient-to-r from-gradient-start via-gradient-center to-gradient-end bg-clip-text text-transparent font-black uppercase leading-none">VI</span>
      <span class="text-6xl block bg-gradient-to-r from-gradient-start via-gradient-center to-gradient-end bg-clip-text text-transparent font-black uppercase leading-none">Foro</span>
      <span class="text-6xl block bg-gradient-to-r from-gradient-start via-gradient-center to-gradient-end bg-clip-text text-transparent font-black uppercase leading-none">2026</span>
    </h1>

    <Image
      src={heroLogoMobile}
      alt="Doctores"
      class="w-[200px]"
      loading="eager"
      fetchpriority="high"
      width={320}
      format="png"
      quality={80}
    />

    <h3 class="text-green-600 flex flex-col w-full items-start justify-start leading-3 font-thin text-2xl mt-3 mb-6">
      <span>"UNA SOLA SALUD" ANTE LA</span><br/>
      <span>RESISTENCIA MICROBIANA</span><br/>
    </h3>

    <div class="bg-gradient-to-r from-gradient-start via-gradient-center to-gradient-end rounded-[20px] px-6 py-2 inline-block mb-3">
      <p class="text-white font-extrabold uppercase text-xl leading-tight tracking-wide text-left">
        El desafío de las infecciones
      </p>
    </div>

    <p class="text-black text-3xl font-bold">
      27 Y 28 DE <br />AGOSTO, 2026
    </p>

    <div class="flex flex-col items-start justify-start w-full">
      <p class="flex w-full flex-col text-black text-2xl text-center font-normal tracking-wide">
        SEDE | Auditorio del <br /><strong class="font-extrabold">Hospital Médica Sur</strong>
      </p>
      <div class="h-1 w-full mt-1 rounded-full bg-gradient-to-r from-gradient-start via-gradient-center to-gradient-end"></div>
    </div>

    <span class="px-4 py-1 rounded-full text-white font-semibold text-base shadow bg-gradient-to-r from-gradient-start via-gradient-center to-gradient-end mt-10 mb-2">
      AVAL ACADÉMICO
    </span>
    <Image
      src={msLogo}
      alt="Médica Sur"
      class="h-20 w-auto"
      width={200}
      height={60}
      loading="lazy"
      decoding="async"
      format="png"
      quality={80}
    />
  </div>

</section>